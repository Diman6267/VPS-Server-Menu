#!/bin/bash

# ======================================================================
# –У–Ы–Р–Т–Э–Ђ–Щ –§–Р–Щ–Ы –Ь–Х–Э–Ѓ (–Ь–Ю–Ф–£–Ы–ђ–Э–Р–ѓ –Т–Х–†–°–Ш–ѓ)
# ======================================================================

# –Я–Њ–і–Ї–ї—О—З–∞–µ–Љ –≤—Б–µ –Њ–±—Й–Є–µ –њ–µ—А–µ–Љ–µ–љ–љ—Л–µ –Є —Д—Г–љ–Ї—Ж–Є–Є
source /usr/local/bin/_config_and_utils.sh

# --- –С–Ы–Ю–Ъ –Я–†–Ю–Т–Х–†–Ъ–Ш –Ю–С–Э–Ю–Т–Ы–Х–Э–Ш–Щ ---

function check_for_updates {
    local SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
    cd "$SCRIPT_DIR" || return
    
    [ ! -d .git ] && return

    git fetch origin main &>/dev/null
    
    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main) # –Ш—Б–њ–Њ–ї—М–Ј—Г–µ–Љ —П–≤–љ—Г—О –≤–µ—В–Ї—Г

    if [ "$LOCAL" != "$REMOTE" ]; then
        echo -e "${YELLOW}======================================================"
        echo -e "рЯУҐ ${GREEN}–Ф–Ю–°–Ґ–£–Я–Э–Ю –Ю–С–Э–Ю–Т–Ы–Х–Э–Ш–Х!${NC}"
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "${CYAN}–І—В–Њ –љ–Њ–≤–Њ–≥–Њ:${NC}"
        git log HEAD..origin/main --oneline -n 3 | sed 's/^[a-z0-9]* //;s/^/- /'
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "–Э–∞–ґ–Љ–Є—В–µ ${GREEN}[7]${NC} –і–ї—П –∞–≤—В–Њ–Њ–±–љ–Њ–≤–ї–µ–љ–Є—П."
        echo -e "======================================================${NC}"
        echo ""
        read -p "–Э–∞–ґ–Љ–Є—В–µ [Enter], —З—В–Њ–±—Л –њ—А–Њ–і–Њ–ї–ґ–Є—В—М..." # –Ф–Њ–±–∞–≤–ї—П–µ–Љ –њ–∞—Г–Ј—Г!
    fi
}

# --- –У–Ы–Р–Т–Э–Ю–Х –Ь–Х–Э–Ѓ ---
function show_menu {
    clear
    echo -e "${CYAN}======================================================${NC}"
    echo -e "${CYAN}             рЯЪА –Ь–Х–Э–Ѓ –£–Я–†–Р–Т–Ы–Х–Э–Ш–ѓ –°–Х–†–Т–Х–†–Ю–Ь рЯЪА            ${NC}"
    echo -e "${CYAN}======================================================${NC}"
    
    # --- –С–Ы–Ю–Ъ –Ю–Ґ–Ю–С–†–Р–Ц–Х–Э–Ш–ѓ –•–Р–†–Р–Ъ–Ґ–Х–†–Ш–°–Ґ–Ш–Ъ ---
    # --- –°–С–Ю–† –Ф–Р–Э–Э–Ђ–• –Т –°–Ґ–Ш–Ы–Х BENCH.SH ---
    # CPU
    if command -v lscpu &> /dev/null; then
        CPU_MODEL=$(lscpu 2>/dev/null | grep 'Model name:' | head -n 1 | awk -F ':' '{print $2}' | sed -e 's/^[ \t]*//')
        CPU_CORES=$(nproc)
        CPU_FREQ=$(lscpu | grep -i "CPU MHz" | awk -F': ' '{print $2}' | xargs)
		if [ -z "$CPU_FREQ" ]; then
    CPU_FREQ=$(grep -m1 "cpu MHz" /proc/cpuinfo | awk -F': ' '{print $2}' | xargs)
fi
        CPU_CACHE=$(lscpu | grep "L3 cache" | awk '{print $3$4}')
    else
        CPU_MODEL="–Э–µ –Њ–њ—А–µ–і–µ–ї–µ–љ–Њ"; CPU_CORES="?"; CPU_FREQ="?"; CPU_CACHE="?"
    fi

    # AES-NI / Virtualization
    AES_NI=$(grep -qw aes /proc/cpuinfo && echo -e "${GREEN}вЬУ –Т–Ї–ї—О—З–µ–љ–Њ${NC}" || echo -e "${RED}вЬЧ –Т—Л–Ї–ї—О—З–µ–љ–Њ${NC}")
    VM_X=$(grep -Eow "vmx|svm" /proc/cpuinfo > /dev/null && echo -e "${GREEN}вЬУ –Т–Ї–ї—О—З–µ–љ–Њ${NC}" || echo -e "${RED}вЬЧ –Т—Л–Ї–ї—О—З–µ–љ–Њ${NC}")
    VIRT=$(systemd-detect-virt 2>/dev/null || echo "Unknown")

    # DISK & MEM (–Ш—Б–њ–Њ–ї—М–Ј—Г–µ–Љ —В–≤–Њ–Є —Б—Г—Й–µ—Б—В–≤—Г—О—Й–Є–µ —А–∞—Б—З–µ—В—Л —Б bc) [cite: 8]
    RAM_TOTAL_RAW=$(grep MemTotal /proc/meminfo | awk '{print $2/1024/1024}')
    RAM_TOTAL=$(printf "%.1f" $RAM_TOTAL_RAW)
    MEM_FREE=$(grep MemAvailable /proc/meminfo | awk '{print $2/1024/1024}')
    MEM_USED=$(echo "$RAM_TOTAL - $MEM_FREE" | bc -l)
    
    DISK_USAGE=$(df -h --output=size,used / | tail -n 1)
    read -r D_TOTAL D_USED <<< "$DISK_USAGE"

    # SYSTEM INFO
    UPTIME_RAW=$(uptime -p | sed 's/up //')
    UPTIME=$(echo "$UPTIME_RAW" | sed -e 's/years\?/–ї–µ—В/g' -e 's/weeks\?/–љ–µ–і–µ–ї—М/g' -e 's/days\?/–і–љ./g' -e 's/hours\?/—З–∞—Б./g' -e 's/minutes\?/–Љ–Є–љ./g')
    LOAD_AVG=$(awk '{print $1", "$2", "$3}' /proc/loadavg)
    OS_NAME=$(grep "PRETTY_NAME" /etc/os-release | cut -d'"' -f2)
    ARCH=$(uname -m)
    KERNEL=$(uname -r)
    TCP_CC=$(sysctl net.ipv4.tcp_congestion_control | awk '{print $3}')

    # NETWORK & GEO 
    IPV4=$(curl -s4 ipinfo.io/ip 2>/dev/null || echo -e "${RED}вЬЧ Offline${NC}")
    IPV6=$(get_public_ipv6)
    GEO_DATA=$(curl -s "http://ip-api.com/json/$PUBLIC_IPV4?lang=ru&fields=status,message,country,regionName,city,isp,org,as")
    COUNTRY=$(echo "$GEO_DATA" | jq -r '.country' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"country":"\K[^"]+')
    LOC=$(echo "$GEO_DATA" | jq -r '.city' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"city":"\K[^"]+')
    REG=$(echo "$GEO_DATA" | jq -r '.regionName' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"regionName":"\K[^"]+')
    ORG=$(echo "$GEO_DATA" | jq -r '.org' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"org":"\K[^"]+')
    if [ -z "$ORG" ] || [ "$ORG" == "null" ]; then
        ORG=$(echo "$GEO_DATA" | jq -r '.isp' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"isp":"\K[^"]+')
    fi
    # --- –Т–Ђ–Т–Ю–Ф –Ь–Х–Э–Ѓ –Т –°–Ґ–Ш–Ы–Х BENCH.SH ---
    echo -e "${BLUE}----------------------------------------------------------------------${NC}"
    echo -e " –Ь–Њ–і–µ–ї—М –њ—А–Њ—Ж–µ—Б—Б–Њ—А–∞   : ${YELLOW}$CPU_MODEL${NC}"
    echo -e " –ѓ–і—А–∞ –њ—А–Њ—Ж–µ—Б—Б–Њ—А–∞     : ${YELLOW}$CPU_CORES @ ${CPU_FREQ} MHz${NC}"
    echo -e " –Ъ—Н—И –њ—А–Њ—Ж–µ—Б—Б–Њ—А–∞      : ${YELLOW}$CPU_CACHE${NC}"
    echo -e " AES-NI              : $AES_NI"
    echo -e " VM-x/AMD-V          : $VM_X"
    echo -e " –Т—Б–µ–≥–Њ –і–Є—Б–Ї–∞         : ${YELLOW}$D_TOTAL ($D_USED –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Њ)${NC}"
    echo -e " –Т—Б–µ–≥–Њ –њ–∞–Љ—П—В–Є        : ${YELLOW}$RAM_TOTAL GB ($(printf "%.1f" $MEM_USED) GB –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Њ)${NC}"
    echo -e " –Т—А–µ–Љ—П —А–∞–±–Њ—В—Л        : ${YELLOW}$UPTIME${NC}"
    echo -e " –°—А–µ–і–љ—П—П –љ–∞–≥—А—Г–Ј–Ї–∞    : ${YELLOW}$LOAD_AVG${NC}"
    echo -e " –Ю–°                  : ${YELLOW}$OS_NAME${NC}"
    echo -e " –Р—А—Е–Є—В–µ–Ї—В—Г—А–∞         : ${YELLOW}$ARCH (64 Bit)${NC}"
    echo -e " –ѓ–і—А–Њ                : ${YELLOW}$KERNEL${NC}"
    echo -e " TCP CC              : ${YELLOW}$TCP_CC${NC}"
    echo -e " –Т–Є—А—В—Г–∞–ї–Є–Ј–∞—Ж–Є—П       : ${YELLOW}$VIRT${NC}"
    echo -e " IPv4 / IPv6         : ${GREEN}$IPV4${NC} / ${GREEN}${IPV6}${NC}"
    echo -e " –°—В—А–∞–љ–∞              : ${YELLOW}$COUNTRY${NC}"
    echo -e " –Ю—А–≥–∞–љ–Є–Ј–∞—Ж–Є—П         : ${YELLOW}$ORG${NC}"
    echo -e " –Ы–Њ–Ї–∞—Ж–Є—П             : ${YELLOW}$LOC${NC}"
    echo -e " –†–µ–≥–Є–Њ–љ              : ${YELLOW}$REG${NC}"
    echo -e "${BLUE}----------------------------------------------------------------------${NC}"
    
    # –°–Ґ–Р–Ґ–£–° –Я–†–Ш–Ы–Ю–Ц–Х–Э–Ш–Щ
    echo -e "${BLUE}--- –°–Ґ–Р–Ґ–£–° –Я–†–Ш–Ы–Ю–Ц–Х–Э–Ш–Щ --------------------------------${NC}"
    # –Я—А–Њ–≤–µ—А–Ї–∞ X-UI
    if systemctl is-active --quiet x-ui; then status_xui="${GREEN}–†–Р–С–Ю–Ґ–Р–Х–Ґ${NC}"; else status_xui="${RED}–Ю—Б—В–∞–љ–Њ–≤–ї–µ–љ${NC}"; fi
    
    # –Ш—Б–њ—А–∞–≤–ї–µ–љ–љ–∞—П –њ—А–Њ–≤–µ—А–Ї–∞ Hysteria2 (–Є—Й–µ—В –ї—О–±–Њ–є —О–љ–Є—В, —Б–Њ–і–µ—А–ґ–∞—Й–Є–є hysteria)
    if systemctl list-units --type=service --state=running | grep -qi "hysteria"; then 
        status_hy2="${GREEN}–†–Р–С–Ю–Ґ–Р–Х–Ґ${NC}"
    else 
        status_hy2="${RED}–Ю—Б—В–∞–љ–Њ–≤–ї–µ–љ${NC}"
    fi
    
    # –Я—А–Њ–≤–µ—А–Ї–∞ MTProxy (–њ–Њ –Є–Љ–µ–љ–Є –Ї–Њ–љ—В–µ–є–љ–µ—А–∞ –≤ Docker)
    if sudo docker ps --format '{{.Names}}' | grep -q "mtproto-proxy"; then 
        status_mtp="${GREEN}–†–Р–С–Ю–Ґ–Р–Х–Ґ${NC}"
    else 
        status_mtp="${RED}–Ю—Б—В–∞–љ–Њ–≤–ї–µ–љ${NC}"
    fi

    echo -e "    X-UI:        [$status_xui]"
    echo -e "    Hysteria2:   [$status_hy2]"
    echo -e "    MTProxy:     [$status_mtp]"
    
    echo -e "${BLUE}--- –Ф–Х–Щ–°–Ґ–Т–Ш–ѓ ---------------------------------------${NC}"
    echo -e "${YELLOW}1) –£–њ—А–∞–≤–ї–µ–љ–Є–µ X-UI (–£—Б—В–∞–љ–Њ–≤–Ї–∞/–Ч–∞–њ—Г—Б–Ї/–Э–∞—Б—В—А–Њ–є–Ї–∞)${NC}"
    echo -e "${YELLOW}2) –£–њ—А–∞–≤–ї–µ–љ–Є–µ Hysteria2 (–£—Б—В–∞–љ–Њ–≤–Ї–∞/–°—В–∞—А—В/–°—В–Њ–њ/–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є)${NC}"
    echo -e "${BLUE}3) –£–њ—А–∞–≤–ї–µ–љ–Є–µ MTProxy (Docker/–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є/–С–Њ—В)${NC}"
    echo -e "${YELLOW}4) –Ґ–µ—Б—В–Є—А–Њ–≤–∞–љ–Є–µ —Б–µ—А–≤–µ—А–∞ (–°–Ї–Њ—А–Њ—Б—В—М/–С–ї–Њ–Ї–Є—А–Њ–≤–Ї–Є/–°–Ї–∞–љ–µ—А)${NC}"
    echo -e "${YELLOW}5) –Э–∞—Б—В—А–Њ–є–Ї–∞ –Є –Њ–њ—В–Є–Љ–Є–Ј–∞—Ж–Є—П —Б–µ—А–≤–µ—А–∞${NC}"
    echo -e "${GREEN}6) –Ь–µ–љ—О IPv6 (–Т–Ї–ї/–Т—Л–Ї–ї/–°—В–∞—В—Г—Б)${NC}"
    echo -e "${CYAN}7) рЯФД –Ю–С–Э–Ю–Т–Ш–Ґ–ђ –°–Ъ–†–Ш–Я–Ґ–Ђ (—Б GitHub)${NC}"
    echo -e "${RED}X) –Т—Л—Е–Њ–і –≤ –Њ–±–Њ–ї–Њ—З–Ї—Г${NC}"
    echo -e "${RED}T) –Ґ–µ—Б—В2${NC}"
    echo -e "${BLUE}------------------------------------------------------${NC}"
}

# –У–Ы–Р–Т–Э–Ђ–Щ –¶–Ш–Ъ–Ы –Ч–Р–Я–£–°–Ъ–Р - –≤—Л–Ј—Л–≤–∞–µ—В –≤–љ–µ—И–љ–Є–µ —Б–Ї—А–Є–њ—В—Л
while true; do
    # 1. –°–Э–Р–І–Р–Ы–Р –Я–†–Ю–Т–Х–†–ѓ–Х–Ь –Ю–С–Э–Ю–Т–Ы–Х–Э–Ш–ѓ
    # –Х—Б–ї–Є –Њ–±–љ–Њ–≤–ї–µ–љ–Є–µ –µ—Б—В—М, —Б—А–∞–±–Њ—В–∞–µ—В read –≤–љ—Г—В—А–Є —Д—Г–љ–Ї—Ж–Є–Є –Є –Ј–∞–і–µ—А–ґ–Є—В —Н–Ї—А–∞–љ
    check_for_updates 

    # 2. –Я–Ю–Ґ–Ю–Ь –†–Ш–°–£–Х–Ь –Ь–Х–Э–Ѓ (–Ј–і–µ—Б—М —Б—А–∞–±–Њ—В–∞–µ—В clear)
    show_menu
    
    PROMPT=$(echo -e "${CYAN}–Т–∞—И –≤—Л–±–Њ—А [1-7, X]: ${NC}")
    read -p "$PROMPT" choice

    case $choice in
        1) /usr/local/bin/menu_xui.sh ;;
        2) /usr/local/bin/menu_hysteria.sh ;;
        3) /usr/local/bin/menu_mtproxy.sh ;;
        4) /usr/local/bin/menu_tests.sh ;;
        5) /usr/local/bin/menu_setup.sh ;;
        6) /usr/local/bin/ipv6-menu ;;
        7)
           echo -e "${YELLOW}>>> –Я—А–Є–љ—Г–і–Є—В–µ–ї—М–љ–Њ–µ –Њ–±–љ–Њ–≤–ї–µ–љ–Є–µ —З–µ—А–µ–Ј Git...${NC}"
           SCRIPT_PATH=$(readlink -f "$0")
           SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
           cd "$SCRIPT_DIR" || exit
           
           git fetch origin main &>/dev/null
           if git reset --hard origin/main; then
               chmod +x server-menu
               # –Ф–∞–µ–Љ –њ—А–∞–≤–∞ –Є –Њ—Б—В–∞–ї—М–љ—Л–Љ —Б–Ї—А–Є–њ—В–∞–Љ –≤ –њ–∞–њ–Ї–µ, —З—В–Њ–±—Л –љ–µ –±—Л–ї–Њ Permission denied
               chmod +x *.sh 2>/dev/null 
               echo -e "${GREEN}вЬЕ –Ю–±–љ–Њ–≤–ї–µ–љ–Њ –і–Њ –њ–Њ—Б–ї–µ–і–љ–µ–є –≤–µ—А—Б–Є–Є GitHub!${NC}"
               sleep 1
               exec bash "$0"
           else
               echo -e "${RED}вЭМ –Ъ—А–Є—В–Є—З–µ—Б–Ї–∞—П –Њ—И–Є–±–Ї–∞ –Њ–±–љ–Њ–≤–ї–µ–љ–Є—П.${NC}"
               read -p "–Э–∞–ґ–Љ–Є—В–µ Enter..."
           fi
           ;;
      [Xx])
            echo -e "${GREEN}–Т—Л—Е–Њ–і –≤ –Њ–±–Њ–ї–Њ—З–Ї—Г.${NC}"
            break
            ;;
        *)
            echo -e "${RED}вЭМ –Э–µ–≤–µ—А–љ—Л–є –≤–≤–Њ–і.${NC}"
            sleep 1
            ;;
    esac
done

#!/bin/bash

# ======================================================================
# ГЛАВНЫЙ ФАЙЛ МЕНЮ (МОДУЛЬНАЯ ВЕРСИЯ)
# ======================================================================

# Подключаем все общие переменные и функции
source /usr/local/bin/_config_and_utils.sh

# --- БЛОК ПРОВЕРКИ ОБНОВЛЕНИЙ ---
function check_for_updates {
    # Переходим в физическую папку репозитория
    cd /root/VPS-Server-Menu || return
    
    [ ! -d .git ] && return

    git fetch origin main &>/dev/null
    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main)

    if [ "$LOCAL" != "$REMOTE" ]; then
        echo -e "${YELLOW}======================================================"
        echo -e "📢 ${GREEN}ДОСТУПНО ОБНОВЛЕНИЕ!${NC}"
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "${CYAN}Что нового:${NC}"
        git log HEAD..origin/main --oneline -n 3 | sed 's/^[a-z0-9]* //;s/^/- /'
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "Нажмите ${GREEN}[7]${NC} для обновления."
        echo -e "======================================================${NC}"
        echo ""
        read -p "Нажмите [Enter], чтобы продолжить..."
    fi
}

# --- ГЛАВНОЕ МЕНЮ ---
function show_menu {
    clear
    echo -e "${CYAN}======================================================${NC}"
    echo -e "${CYAN}            🚀 МЕНЮ УПРАВЛЕНИЯ СЕРВЕРОМ 🚀             ${NC}"
    echo -e "${CYAN}======================================================${NC}"
    
    # ... (тут твой код сбора характеристик процессора, памяти и т.д.) ...
    # (я пропускаю его для краткости, оставь свой как есть)
    
    echo -e "${BLUE}--- ДЕЙСТВИЯ ---------------------------------------${NC}"
    echo -e "${YELLOW}1) Управление X-UI${NC}"
    echo -e "${YELLOW}2) Управление Hysteria2${NC}"
    echo -e "${BLUE}3) Управление MTProxy${NC}"
    echo -e "${YELLOW}4) Тестирование сервера${NC}"
    echo -e "${YELLOW}5) Настройка и оптимизация${NC}"
    echo -e "${GREEN}6) Меню IPv6${NC}"
    echo -e "${CYAN}7) 🔄 ОБНОВИТЬ СКРИПТЫ (с GitHub)${NC}"
    echo -e "${RED}X) Выход в оболочку${NC}"
    echo -e "${BLUE}------------------------------------------------------${NC}"
}

# ======================================================================
# ГЛАВНЫЙ ЦИКЛ ЗАПУСКА
# ======================================================================
while true; do
    # 1. ВЫЗЫВАЕМ ПРОВЕРКУ ОБНОВЛЕНИЙ ПЕРЕД МЕНЮ
    check_for_updates 

    # 2. РИСУЕМ МЕНЮ
    show_menu
    
    PROMPT=$(echo -e "${CYAN}Ваш выбор [1-7, X]: ${NC}")
    read -p "$PROMPT" choice

    case $choice in
        1) /usr/local/bin/menu_xui.sh ;;
        2) /usr/local/bin/menu_hysteria.sh ;;
        3) /usr/local/bin/menu_mtproxy.sh ;;
        4) /usr/local/bin/menu_tests.sh ;;
        5) /usr/local/bin/menu_setup.sh ;;
        6) /usr/local/bin/ipv6-menu ;;
        7)
           echo -e "${YELLOW}>>> Принудительное обновление через Git...${NC}"
           cd /root/VPS-Server-Menu || exit
           git fetch origin main &>/dev/null
           if git reset --hard origin/main; then
               chmod +x /root/VPS-Server-Menu/*
               echo -e "${GREEN}✅ Обновлено! Перезапуск...${NC}"
               sleep 1
               exec bash "$0"
           else
               echo -e "${RED}❌ Ошибка обновления.${NC}"
               read -p "Нажмите Enter..."
           fi
           ;;
        [Xx])
            echo -e "${GREEN}Выход.${NC}"
            break
            ;;
        *)
            echo -e "${RED}❌ Неверный ввод.${NC}"
            sleep 1
            ;;
    esac
done
